# Port for the server
PORT=5050

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=dermalyze

# JWT Secret for Authentication
JWT_SECRET=your_super_secret_jwt_key_here

# Hugging Face API Token (for skin analysis)
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=xxxxxxxxx
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Deployment Environment
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Email Configuration (Resend API)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Dermalyze <onboarding@resend.dev>

# Admin Configuration (for doctor verification alerts and seeding)
ADMIN_EMAIL=admin@dermalyze.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Admin
